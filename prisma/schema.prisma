generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConversationStatus {
  idle
  streaming
  error
  archived
}

enum MessageRole {
  user
  assistant
  system
}

enum MessageStatus {
  pending
  streaming
  completed
  failed
}

enum AttachmentStatus {
  uploaded
  reused
  failed
}

enum EventLogLevel {
  info
  warning
  error
}

model Conversation {
  id                  String             @id @default(cuid())
  title               String             @default("Nouvelle conversation")
  titleManuallyEdited Boolean            @default(false)
  simMemoryKey        String             @unique
  status              ConversationStatus @default(idle)
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?
  messages            Message[]
  eventLogs           EventLog[]

  @@index([updatedAt, deletedAt])
}

model Message {
  id              String        @id @default(cuid())
  conversationId  String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            MessageRole
  content         String        @default("")
  status          MessageStatus @default(pending)
  clientRequestId String?
  providerMessageId String?
  metadata        Json?
  error           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  attachments     Attachment[]
  eventLogs       EventLog[]

  @@index([conversationId, createdAt])
  @@unique([conversationId, clientRequestId])
}

model Attachment {
  id           String           @id @default(cuid())
  messageId    String
  message      Message          @relation(fields: [messageId], references: [id], onDelete: Cascade)
  originalName String
  mimeType     String
  size         Int
  status       AttachmentStatus @default(uploaded)
  storageKey   String
  checksum     String?
  createdAt    DateTime         @default(now())

  @@index([messageId])
}

model EventLog {
  id             String        @id @default(cuid())
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  messageId      String?
  message        Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  level          EventLogLevel @default(info)
  kind           String
  durationMs     Int?
  payload        Json
  createdAt      DateTime      @default(now())
}
